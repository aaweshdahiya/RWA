# backend/model.py (Price Prediction)
# =============================
import pandas as pd
from sklearn.linear_model import LinearRegression

class PriceModel:
    def __init__(self):
        self.model = LinearRegression()

    def train(self, path="data/sample_data.csv"):
        df = pd.read_csv(path)
        X = df[["size", "location_score", "amenities_score"]]
        y = df["price"]
        self.model.fit(X, y)

    def predict(self, size, location_score, amenities_score):
        return self.model.predict([[size, location_score, amenities_score]])[0]

